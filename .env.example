# Database — SQLite for local dev, Postgres (Neon) for prod
DATABASE_URL="file:./prisma/dev.db"

# Auth — generate with: openssl rand -base64 32  OR  pwsh: [Convert]::ToBase64String((1..32 | %{Get-Random -Min 0 -Max 255}))
AUTH_SECRET="change-me-to-a-random-32-byte-base64-string"
AUTH_TRUST_HOST="true"

# Seed admin (used on `pnpm db:seed`). Defaults match plan; override if you want.
SEED_ADMIN_USERNAME="ankur"
SEED_ADMIN_PASSWORD="ankur@123"
SEED_ADMIN_EMAIL="ankur.aries@gmail.com"

# Vercel Blob (optional in dev; falls back to local /public/uploads)
BLOB_READ_WRITE_TOKEN=""

# Resend (Phase 2+)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="no-reply@adwitiya.example"
